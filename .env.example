# Copy this file to .env for local development or container runtime defaults.
# The Bun server loads .env automatically on startup.

# HTTP port used by the Bun server inside the container.
PORT=3000

# Persistent data directory for SQLite, generated app key, sessions, and settings.
DATA_DIR=/data

# Optional explicit SQLite database path.
# Defaults to $DATA_DIR/registry-ui.sqlite.
# DATABASE_PATH=/data/registry-ui.sqlite

# Optional secret used to encrypt stored registry credentials.
# If omitted, the app generates and reuses APP_KEY_PATH.
# APP_SECRET=change-me-to-a-long-random-secret

# Optional path for the generated encryption key when APP_SECRET is omitted.
# Defaults to $DATA_DIR/app.key.
# APP_KEY_PATH=/data/app.key
